{
  "info": {
    "name": "Clinic Appointment System",
    "description": "Complete API collection for the Clinic Appointment System microservices. Includes success and failure test cases for every endpoint.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "bookingUrl", "value": "http://localhost:4001" },
    { "key": "patientUrl", "value": "http://localhost:4002" },
    { "key": "reminderUrl", "value": "http://localhost:4003" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Patient Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{patientUrl}}/health"
          }
        },
        {
          "name": "Register Patient (success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"555-0200\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Register Patient — missing fields (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"\"\n}"
            }
          }
        },
        {
          "name": "Register Patient — bad email (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test\",\n  \"email\": \"not-an-email\",\n  \"phone\": \"555\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login Patient (success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login Patient — wrong password (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        },
        {
          "name": "Login Patient — missing fields (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"\"\n}"
            }
          }
        },
        {
          "name": "Get Profile (success)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{patientUrl}}/api/patients/1"
          }
        },
        {
          "name": "Get Profile — no token (401)",
          "request": {
            "method": "GET",
            "url": "{{patientUrl}}/api/patients/1"
          }
        },
        {
          "name": "Get Profile — bad token (403)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer invalid.token.here" }],
            "url": "{{patientUrl}}/api/patients/1"
          }
        },
        {
          "name": "Get Profile — not found (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{patientUrl}}/api/patients/99999"
          }
        },
        {
          "name": "Update Profile (success)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{patientUrl}}/api/patients/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane M. Doe\",\n  \"phone\": \"555-0300\"\n}"
            }
          }
        },
        {
          "name": "Update Profile — no token (401)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Hack\"\n}"
            }
          }
        },
        {
          "name": "Delete Profile (success)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{patientUrl}}/api/patients/1"
          }
        },
        {
          "name": "Delete Profile — no token (401)",
          "request": {
            "method": "DELETE",
            "url": "{{patientUrl}}/api/patients/1"
          }
        }
      ]
    },
    {
      "name": "Booking Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/health"
          }
        },
        {
          "name": "Get All Appointments",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/api/appointments"
          }
        },
        {
          "name": "Get Appointment by ID (success)",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/api/appointments/1"
          }
        },
        {
          "name": "Get Appointment — not found (404)",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/api/appointments/99999"
          }
        },
        {
          "name": "Create Appointment (success)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{bookingUrl}}/api/appointments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"patientName\": \"Jane Doe\",\n  \"patientContact\": \"555-0200\",\n  \"doctorName\": \"Dr. Smith\",\n  \"appointmentDate\": \"2026-08-15\",\n  \"appointmentTime\": \"10:00\"\n}"
            }
          }
        },
        {
          "name": "Create Appointment — missing fields (400)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{bookingUrl}}/api/appointments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1\n}"
            }
          }
        },
        {
          "name": "Create Appointment — no token (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{bookingUrl}}/api/appointments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"patientName\": \"Jane\",\n  \"patientContact\": \"555\",\n  \"doctorName\": \"Dr. Smith\",\n  \"appointmentDate\": \"2026-08-15\",\n  \"appointmentTime\": \"10:00\"\n}"
            }
          }
        },
        {
          "name": "Create Appointment — bad token (403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer invalid.token.here" }
            ],
            "url": "{{bookingUrl}}/api/appointments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"patientName\": \"Jane\",\n  \"patientContact\": \"555\",\n  \"doctorName\": \"Dr. Smith\",\n  \"appointmentDate\": \"2026-08-15\",\n  \"appointmentTime\": \"10:00\"\n}"
            }
          }
        },
        {
          "name": "Update Appointment (success)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{bookingUrl}}/api/appointments/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorName\": \"Dr. Jones\",\n  \"appointmentTime\": \"11:00\"\n}"
            }
          }
        },
        {
          "name": "Update Appointment — not found (404)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{bookingUrl}}/api/appointments/99999",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorName\": \"Dr. Jones\"\n}"
            }
          }
        },
        {
          "name": "Cancel Appointment (success)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{bookingUrl}}/api/appointments/1"
          }
        },
        {
          "name": "Cancel Appointment — not found (404)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{bookingUrl}}/api/appointments/99999"
          }
        },
        {
          "name": "Cancel Appointment — no token (401)",
          "request": {
            "method": "DELETE",
            "url": "{{bookingUrl}}/api/appointments/1"
          }
        }
      ]
    },
    {
      "name": "Reminder Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{reminderUrl}}/health"
          }
        },
        {
          "name": "Get All Reminders",
          "request": {
            "method": "GET",
            "url": "{{reminderUrl}}/api/reminders"
          }
        },
        {
          "name": "Get Reminder by ID",
          "request": {
            "method": "GET",
            "url": "{{reminderUrl}}/api/reminders/665f1a2b3c4d5e6f7a8b9c0d"
          }
        },
        {
          "name": "Get Reminder — not found (404)",
          "request": {
            "method": "GET",
            "url": "{{reminderUrl}}/api/reminders/000000000000000000000000"
          }
        }
      ]
    }
  ]
}
