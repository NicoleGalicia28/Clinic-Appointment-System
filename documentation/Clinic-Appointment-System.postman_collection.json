{
  "info": {
    "name": "Clinic Appointment System",
    "description": "Complete API collection for the Clinic Appointment System microservices.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "bookingUrl", "value": "http://localhost:4001" },
    { "key": "patientUrl", "value": "http://localhost:4002" },
    { "key": "reminderUrl", "value": "http://localhost:4003" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Patient Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{patientUrl}}/health"
          }
        },
        {
          "name": "Register Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"555-0200\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{patientUrl}}/api/patients/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{patientUrl}}/api/patients/1"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{patientUrl}}/api/patients/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane M. Doe\",\n  \"phone\": \"555-0300\"\n}"
            }
          }
        },
        {
          "name": "Delete Profile",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{patientUrl}}/api/patients/1"
          }
        }
      ]
    },
    {
      "name": "Booking Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/health"
          }
        },
        {
          "name": "Get All Appointments",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/api/appointments"
          }
        },
        {
          "name": "Get Appointment by ID",
          "request": {
            "method": "GET",
            "url": "{{bookingUrl}}/api/appointments/1"
          }
        },
        {
          "name": "Create Appointment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{bookingUrl}}/api/appointments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"patientName\": \"Jane Doe\",\n  \"patientContact\": \"555-0200\",\n  \"doctorName\": \"Dr. Smith\",\n  \"appointmentDate\": \"2026-08-15\",\n  \"appointmentTime\": \"10:00\"\n}"
            }
          }
        },
        {
          "name": "Update Appointment",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{bookingUrl}}/api/appointments/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorName\": \"Dr. Jones\",\n  \"appointmentTime\": \"11:00\"\n}"
            }
          }
        },
        {
          "name": "Cancel Appointment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{bookingUrl}}/api/appointments/1"
          }
        }
      ]
    },
    {
      "name": "Reminder Service",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{reminderUrl}}/health"
          }
        },
        {
          "name": "Get All Reminders",
          "request": {
            "method": "GET",
            "url": "{{reminderUrl}}/api/reminders"
          }
        }
      ]
    }
  ]
}
